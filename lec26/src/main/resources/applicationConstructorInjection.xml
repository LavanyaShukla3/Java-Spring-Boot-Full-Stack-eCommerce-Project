<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <!--       Spring:
                When creating the object,-->
    <!--        call this method:-->
    <!--        setMessage("I am a first bean")-->
    <!--            This is called: Dependency Injection ( Spring injects values into objects)-->
    <bean id="carSpecification" class="car.example.constrctor.injection.Specification">
<!--        Setter Injection-->
        <property name="make" value="Toyota"/>
        <property name="model" value="Corolla"/>
    </bean>
    <bean id="myCar" class="car.example.constrctor.injection.Car">
<!--        Constructor Injection-->
        <constructor-arg ref="carSpecification"/>
    </bean>
</beans>